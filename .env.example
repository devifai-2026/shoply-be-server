# Server
PORT=5000
NODE_ENV=development

# MongoDB (commerce data). For SaaS, the control plane uses SAAS_CONTROL_DB_URI.
MONGODB_URI=mongodb://127.0.0.1:27017/ecom
SAAS_CONTROL_DB_URI=mongodb://127.0.0.1:27017/saas_control

# JWT (tenant/admin/customer) + platform owner (separate secret)
JWT_SECRET=change_me_generate_a_long_random_string
JWT_EXPIRES_IN=7d
OWNER_JWT_SECRET=change_me_separate_owner_secret

# Encryption key for tenant secrets (64-char hex). Generate: openssl rand -hex 32
SECRET_ENC_KEY=

# CI build callback shared secret. Generate: openssl rand -hex 16
BUILD_CALLBACK_SECRET=

# Admin default credentials (used only during first seed)
ADMIN_EMAIL=admin@store.com
ADMIN_PASSWORD=change_me

# Platform owner default (used only by seed-owner.js)
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change_me

# SaaS public domain for tenant URL derivation (e.g. 34-93-178-29.sslip.io)
SAAS_PUBLIC_DOMAIN=localhost
SAAS_ROOT_DOMAIN=localhost

# GitHub Actions build dispatch (per-tenant APK builds)
GITHUB_BUILD_TOKEN=
GITHUB_USER_REPO=owner/repo
GITHUB_BUILD_WORKFLOW=tenant-build.yml
BUILD_CALLBACK_BASE=https://api.your-domain

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
